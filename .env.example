# Local frontend override. `npm run dev` detects the teacher laptop LAN address automatically.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional public Supabase values. JavaShare normally accesses Supabase through
# its backend, so leave these blank unless the browser later needs them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
