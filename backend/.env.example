PORT=4000
DATABASE_MODE=supabase-online
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:3000
LOCAL_JAVA_EXECUTION=true
JUDGE0_URL=
JUDGE0_API_KEY=

# Use the hosted project values for supabase-online. The offline launcher fills
# these from the local Supabase CLI automatically. Keep SERVICE_ROLE_KEY secret.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Never enable LOCAL_JAVA_EXECUTION on Render; production ignores it by design.
