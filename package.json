{
  "name": "javashare",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "backend"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "classroom": "npm run classroom:online",
    "classroom:online": "node scripts/classroom-mode.mjs online",
    "classroom:offline": "node scripts/classroom-mode.mjs offline",
    "dev:frontend": "next dev --hostname 0.0.0.0",
    "dev:backend": "npm --workspace backend run dev",
    "build": "next build",
    "build:all": "npm run build && npm --workspace backend run build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern backend/dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "supabase": "^2.109.1",
    "typescript": "5.9.3"
  }
}
